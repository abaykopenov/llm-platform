{
    "annotations": {
        "list": []
    },
    "editable": true,
    "panels": [
        {
            "title": "Request Latency (p50/p95/p99)",
            "type": "timeseries",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, rate(vllm:request_latency_bucket[5m]))",
                    "legendFormat": "p50"
                },
                {
                    "expr": "histogram_quantile(0.95, rate(vllm:request_latency_bucket[5m]))",
                    "legendFormat": "p95"
                },
                {
                    "expr": "histogram_quantile(0.99, rate(vllm:request_latency_bucket[5m]))",
                    "legendFormat": "p99"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            }
        },
        {
            "title": "Tokens Per Second",
            "type": "timeseries",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "targets": [
                {
                    "expr": "rate(vllm:generation_tokens_total[5m])",
                    "legendFormat": "tok/s"
                }
            ]
        },
        {
            "title": "Active Requests",
            "type": "stat",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "targets": [
                {
                    "expr": "vllm:num_requests_running",
                    "legendFormat": "Running"
                },
                {
                    "expr": "vllm:num_requests_waiting",
                    "legendFormat": "Waiting"
                }
            ]
        },
        {
            "title": "Time to First Token (TTFT)",
            "type": "timeseries",
            "datasource": "Prometheus",
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 16
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, rate(vllm:time_to_first_token_bucket[5m]))",
                    "legendFormat": "TTFT p50"
                },
                {
                    "expr": "histogram_quantile(0.95, rate(vllm:time_to_first_token_bucket[5m]))",
                    "legendFormat": "TTFT p95"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            }
        }
    ],
