# ============================================================
#  LLM Platform — Environment Configuration
# ============================================================

# --- Inference Nodes (модульный) ---
# Через запятую. Добавьте второй ASUS — просто допишите IP.
# Поддержка: Ollama, vLLM, LM Studio, любой OpenAI-compatible сервер.
INFERENCE_NODES=http://192.168.8.7:11434

# Пример с несколькими узлами:
# INFERENCE_NODES=http://192.168.8.7:11434,http://192.168.8.8:11434,http://192.168.8.9:8300

# Fallback (если INFERENCE_NODES не задан):
# INFERENCE_URL=http://192.168.8.7:11434

# --- Service Ports ---
GATEWAY_PORT=8000
RAG_ENGINE_PORT=8200
CHROMADB_PORT=8400
WEBUI_PORT=3001

# --- RAG ---
EMBEDDING_MODEL=nomic-embed-text
CHUNK_SIZE=800
CHUNK_OVERLAP=100
DEFAULT_COLLECTION=general

# --- Auth (optional) ---
# API_KEYS=key1,key2,key3

# --- Rate Limiting ---
RATE_LIMIT_RPM=60
