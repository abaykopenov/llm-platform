# ============================================================
#  LLM Platform — Environment Configuration
# ============================================================

# --- Inference URL ---
# Для тестирования: указать на локальную Ollama
# Для продакшена: указать на Docker-контейнер или vLLM
INFERENCE_URL=http://host.docker.internal:11434

# --- Service Ports ---
GATEWAY_PORT=8000
RAG_ENGINE_PORT=8200
CHROMADB_PORT=8400
WEBUI_PORT=3001

# --- RAG ---
EMBEDDING_MODEL=nomic-embed-text
CHUNK_SIZE=800
CHUNK_OVERLAP=100
DEFAULT_COLLECTION=general

# --- Auth (optional) ---
# API_KEYS=key1,key2,key3

# --- Rate Limiting ---
RATE_LIMIT_RPM=60
